# ── App ──────────────────────────────────────────────
APP_NAME=ultimate-assistant
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
MASTER_ENCRYPTION_KEY=  # generate with: python scripts/generate_master_key.py

# ── Server ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ultimate_assistant

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS S3 ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET=ultimate-assistant
S3_ENDPOINT_URL=http://localhost:9000  # MinIO for local dev; remove for real AWS

# ── JWT ──────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Rate Limiting ────────────────────────────────────
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── CORS ─────────────────────────────────────────────
# Comma-separated allowed origins (used when DEBUG=false).
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# ── Provider API Keys (for testing / admin fallback) ─
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
ELEVENLABS_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=
FAL_KEY=
